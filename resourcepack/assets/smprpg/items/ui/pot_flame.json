{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "on",
        "model": {
          "type": "minecraft:model",
          "model": "ui:item/pot_flame_on"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "ui:item/pot_flame_off"
    }
  }
}